# local | development | staging | production
DOCKER_WP_ENVIRONMENT_TYPE=local
# core | plugin | theme | "" (when nothing is in development, default is "")
DOCKER_WP_DEVELOPMENT_MODE=
WORDPRESS_TABLE_PREFIX=wp_
# 1 | 0
WORDPRESS_DEBUG=1

# define( 'WP_SITEURL', 'http://localhost' );
# define( 'WP_HOME', 'http://localhost' );

#############################################################################
## WordPress Memory Limits
## https://developer.wordpress.org/advanced-administration/performance/php/#memory-limits
## WordPress will raise the PHP memory_limit to these values if it has permission to do so, but if the php.ini specifies higher amounts, WordPress will not lower the amount allowed.
#############################################################################

## WP_MEMORY_LIMIT declares the amount of memory WordPress should request for rendering the frontend of the website.
# defined('WP_MEMORY_LIMIT') || define( 'WP_MEMORY_LIMIT', '40M' );
## WP_MAX_MEMORY_LIMIT declares the amount of memory WordPress should request for rendering the backend of the website.
# defined('WP_MAX_MEMORY_LIMIT') || define( 'WP_MAX_MEMORY_LIMIT', '256M' );

# entries for wp-config.php
WORDPRESS_CONFIG_EXTRA="
define('WP_ENVIRONMENT_TYPE', getenv_docker('DOCKER_WP_ENVIRONMENT_TYPE', 'development') );
define('WP_DEVELOPMENT_MODE', getenv_docker('DOCKER_WP_DEVELOPMENT_MODE', '') );

define('WP_DEBUG_LOG', true );
define('SCRIPT_DEBUG', true);
define('WP_DEBUG_DISPLAY', false );
define('SAVEQUERIES', true );
defined('WP_CACHE') || define( 'WP_CACHE', true );

define('QM_ENABLE_CAPS_PANEL', false );
define('QM_SHOW_ALL_HOOKS', true );

define('WP_AUTO_UPDATE_CORE', false );
define('DISALLOW_FILE_EDIT', true);
"

