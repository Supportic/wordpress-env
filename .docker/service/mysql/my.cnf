[mysqld]
##########################################################################
## Charset & Authentication
##########################################################################
collation-server              = utf8mb4_unicode_ci
character-set-server          = utf8mb4
default-authentication-plugin = mysql_native_password
datadir                       = /var/lib/mysql

##########################################################################
## InnoDB - Primary Storage Engine Optimization
##########################################################################
# Buffer pool is the most important setting - allocates memory for data/index caching
# For containers: typically 50-75% of available memory. Set conservatively for dev.
innodb_buffer_pool_size       = 512M
innodb_buffer_pool_instances  = 4

# Log file size affects crash recovery speed - larger is faster for heavy loads
innodb_log_file_size          = 256M

# Flush behavior: 2 = flush to OS cache (faster, acceptable for dev)
innodb_flush_log_at_trx_commit = 2

# Reduce fsync frequency for better performance
innodb_flush_method           = O_DIRECT

# Thread concurrency
innodb_thread_concurrency     = 0

# File per table enables better space management
innodb_file_per_table         = 1

##########################################################################
## Connection & Memory Settings
##########################################################################
max_connections               = 100
max_allowed_packet            = 256M
thread_cache_size             = 50
table_open_cache              = 4000
table_definition_cache        = 2000

# Per-connection buffers
sort_buffer_size              = 2M
read_buffer_size              = 2M
read_rnd_buffer_size          = 8M
tmp_table_size                = 32M
max_heap_table_size           = 32M

##########################################################################
## Query Cache (development optimization)
##########################################################################
query_cache_size              = 64M
query_cache_type              = 1
query_cache_limit             = 2M

##########################################################################
## Debugging/Monitoring
##########################################################################
# Log slow queries for debugging (>1 second)
slow_query_log                = 1
slow_query_log_file           = /var/log/mysql/slow.log
long_query_time               = 1
log_queries_not_using_indexes = 1

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
prompt                = '\\u@\\h\\_[\\d]>\\_'
